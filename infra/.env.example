# PostgreSQL
DATABASE_URL=postgresql+psycopg://cortex:cortex@localhost:5432/cortex

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (Celery broker)
CELERY_BROKER_URL=amqp://cortex:cortex@localhost:5672//

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# Spoljni sistemi — stub (default) ili prod (kasnije)
CORTEX_CONNECTORS_MODE=stub

# Auth — mock login + AD SSO stub
AUTH_MOCK_ENABLED=true
AD_TENANT_ID=
AD_CLIENT_ID=
AD_CLIENT_SECRET=
AD_AUTHORITY=https://login.microsoftonline.com/common
AD_REDIRECT_URI=http://localhost:5174/auth/callback
AD_SCOPES=openid profile email

# Weaviate
WEAVIATE_URL=http://localhost:8080

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortex123

# RabbitMQ management API (system health)
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
